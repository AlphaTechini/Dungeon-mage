# Magic Dashboard publishable key. Safe to expose to the browser.
PUBLIC_MAGIC_PUBLISHABLE_KEY=

# ZeroDev Arbitrum Sepolia project RPC URL, including its project identifier.
PUBLIC_ZERODEV_RPC_URL=

# Address emitted by `pnpm contracts:deploy`.
PUBLIC_SESSION_ZERO_GAME_ADDRESS=

# Used only by `pnpm contracts:deploy`. Never expose this value to the browser.
ARBITRUM_SEPOLIA_DEPLOYER_PRIVATE_KEY=

# Receives native Arbitrum Sepolia ETH spent on potions.
ARBITRUM_SEPOLIA_TREASURY_ADDRESS=
